# Carbo Marketing — variáveis de ambiente (Vite, build-time).
# Copie para .env (local) ou cadastre no Vercel (Production/Preview/Development).

# Supabase compartilhado do ecossistema (projeto wpkfirmapxevzpxjovjr).
# A anon/publishable é pública por design (segurança = RLS). Já existe default
# embutido no código; setar aqui só padroniza com os outros apps.
VITE_SUPABASE_URL=https://wpkfirmapxevzpxjovjr.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# Web Push (notificação no celular via Carbo Chat). SEM valor default no código:
# copie o MESMO valor de VITE_VAPID_PUBLIC_KEY de um app já no ar (ops/sales/
# finance/admin) no Vercel. Precisa casar com a chave privada (VAPID_PRIVATE_KEY)
# da Edge Function chat-push do Supabase — NÃO gere uma nova só para este app.
# Sem ela, tudo funciona menos o push.
VITE_VAPID_PUBLIC_KEY=
